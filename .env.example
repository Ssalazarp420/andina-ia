# =========================================================
# ANDINA IA - Variables de entorno (plantilla)
# Copiar este archivo como ".env" y completar con valores reales.
# NUNCA subir el .env real al repositorio.
# =========================================================

# --- Fase 5: LLM de generación ---
LLM_PROVIDER=cohere            # cohere | openai
LLM_API_KEY=
LLM_MODEL_NAME=
LLM_TEMPERATURE=0.1

# --- Fase 3: Modelo de embeddings (debe ser el MISMO en indexación y consulta) ---
EMBEDDING_PROVIDER=cohere
EMBEDDING_API_KEY=not_required_for_oci
EMBEDDING_MODEL_NAME=cohere.embed-multilingual-v3.0

# --- Fase 3: Base de datos vectorial ---
VECTOR_DB_PROVIDER=chroma      # chroma | qdrant | pinecone | weaviate | pgvector | oracle_ai_vector
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=8000
VECTOR_DB_API_KEY=
VECTOR_DB_COLLECTION_NAME=andina_bank_kb

# --- Fase 4: Reranker ---
RERANKER_PROVIDER=cohere       # cohere | cross-encoder-local
RERANKER_API_KEY=
RERANKER_MODEL_NAME=
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
SCORE_THRESHOLD=0.55

# --- Fase 7: Oracle Cloud Infrastructure (OCI) ---
OCI_CONFIG_FILE=~/.oci/config
OCI_CONFIG_PROFILE=DEFAULT
OCI_TENANCY_OCID=
OCI_USER_OCID=
OCI_FINGERPRINT=
OCI_KEY_FILE=~/.oci/oci_api_key.pem
OCI_REGION=sa-saopaulo-1
OCI_COMPARTMENT_OCID=
OCI_OBJECT_STORAGE_BUCKET=andina-bank-documentos
OCI_VAULT_OCID=
OCI_GENAI_CHAT_MODEL_ID=
OCI_GENAI_CHAT_ENDPOINT_ID=
OCI_GENAI_RERANK_MODEL_ID=
OCI_GENAI_RERANK_ENDPOINT_ID=

# --- Fase 6: Interfaz ---
APP_NAME="Andina IA"
APP_ENV=local                  # local | production
STREAMLIT_SERVER_PORT=8501

# --- Fase 8: Observabilidad ---
LOG_LEVEL=INFO
LOG_FORMAT=jsonl
